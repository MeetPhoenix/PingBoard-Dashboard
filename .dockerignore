# ── .dockerignore ─────────────────────────────────────────────
# Files and folders Docker should NOT copy into the build context.
# Without this, node_modules (potentially 100MB+) would be sent
# to the Docker daemon on every build — making builds very slow.
# Docker re-installs dependencies cleanly inside the image anyway.

# Dependencies — Docker installs its own inside the image
node_modules
npm-debug.log*
yarn-error.log*

# Version control
.git
.gitignore
.gitattributes

# Docs and config files not needed at runtime
*.md
.dockerignore
Dockerfile

# Environment files — never bake secrets into images
.env
.env.*
!.env.example

# OS junk
.DS_Store
Thumbs.db
